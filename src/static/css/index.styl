// #0043FE
// #04E9BA
// #F830A1

body
	background #0b0f21 !important

.header-container
	width 100%
	height 100%
	background 
	position relative
	.header-content
		width calc(100% - 100px)
		max-width 1600px
		height 100%
		margin 0 auto
		position relative
		#nav
			width 100%
			height 100px
			.nav-content
				width 100%
				margin 0 auto
				height 100%
				display flex
				justify-content space-between
				align-items center
				.left-container
					display flex
					align-items center
					.logo
						width 46px
						height 46px
						margin-right 75px
					.nav-links-container
						display flex
						align-items center
						.nav-link-button
							color #fff
							font-weight 600
							cursor pointer
							font-size 0.95em
							letter-spacing .5px
							margin-right 45px
							text-decoration none
							text-transform uppercase
							position relative
							&:hover::before
								width 100%
							&::before
								content ""
								width 0
								height 3px
								background #0043FE
								position absolute
								bottom -3px
								left 50%
								transform translateX(-50%)
								transition width .3s
				.lets-talk-button
					height 50px
					width 160px
					background #0043FE
					border-radius 1000px
					display flex
					justify-content center
					align-items center
					cursor pointer
					transition background .3s
					&:hover
						background #0438ca
					.icon
						width 30px
						height 30px
						margin 2px 8px 0 0
					p
						color #fff
						font-weight 600
						font-size 0.95em
						letter-spacing .5px
		#jumbo-content-wrap
			position absolute
			top calc(50% - 40px)
			transform translateY(-50%)
			left 0
			.large-hello-text
				color #0043FE
				font-size 10em
				line-height 100%
			.introduction-text
				color #b8becc
				font-size 2em
				margin 10px 0 0 10px
				line-height 130%
				font-weight 300
				b
					font-weight 300
					color #fff
					position relative
			.view-projects-button
				margin-top 25px
				height 50px
				border 1px solid #1B213A
				width 250px
				border-radius 1000px
				display flex
				justify-content center
				align-items center
				cursor pointer
				transition border-color .3s
				&:hover
					border-color #3d4c88
					.icon
						animation arrowMove .8s infinite
				p
					color #fff
					font-size 1.05em
					letter-spacing .5px
					font-weight 600
				.icon
					width 30px
					height 30px
					margin-left 10px
					transition transform .3s
		.header-bottom-container
			display flex
			position absolute
			bottom 40px
			align-items center
			justify-content space-between
			width 100%
			#sm-container
				display flex
				align-items center
				margin-top -5px
				.social-media-button
					width 50px
					height 50px
					margin-left 40px
					border-radius 40px
					display block
					background #1c213a
					position relative
					cursor pointer
					transition background .3s
					&:hover
						background #0043fe
					.icon
						position absolute
						top 50%
						left 50%
						transform translate(-50%, -50%)
			#scroll-down-button
				display flex
				align-items center
				cursor pointer
				&:hover .icon
					animation arrowBounce .8s infinite
				.text
					color #fff
					font-size 1.1em
					letter-spacing .5px
					font-weight 500
				.icon
					width 28px
					height 28px
					margin-left 8px
					transform rotate(90deg)

#main
	width calc(100% - 100px)
	max-width 1600px
	margin 200px auto
	position relative
	.container-title-wrap
		display flex
		align-items center
		margin-bottom 50px
		h1
			color #0043FE
			letter-spacing .5px
			margin-right 10px
			font-size 4.5em
			text-transform uppercase
			line-height 100%
		.divider
			width 75px
			height 5px
			background #1c213a
	.about-me-container
		width 100%
		.about-text-container	
			width 100%
			margin 0 auto
			.about-text
				color #fff
				font-size 1.1em
				line-height 150%
				margin-bottom 20px
				letter-spacing .3px
			.about-me-links-container
				display flex
				align-items center
				margin-top 40px
				.contact-me-link
					margin-right 40px
				a
					display flex
					align-items center
					text-decoration none
					width fit-content
					cursor pointer
					&:hover
						.value
							color #1250ff
						path
							fill #1250ff
					svg
						width 30px
						height 30px
						margin-right 8px
						path
							fill #b8becc
							transition fill .3s
					.value
						color #b8becc
						font-size 1.2em
						letter-spacing .5px
						font-weight 500
						
						transition color .3s
					
	.projects-container
		margin-top 200px
		width 100%
		position relative
		.projects-content
			display flex
			flex-flow row wrap
			width 100%
			.project
				width calc(33.3% - 10px)
				height fit-content
				position relative
				overflow hidden
				cursor pointer
				margin 0 15px 15px 0
				&:nth-child(3n)
					margin-right 0
				&:hover
					.more-info-button
						bottom calc(-100% + 55px)
					.overlay
						opacity 1
				.more-info-button
					position absolute
					height 100%
					width 100%
					background #1250ff
					cursor pointer
					bottom -100%
					z-index 3
					transition bottom .3s cubic-bezier(0.34, 1.56, 0.64, 1)
					.button-content
						display flex
						align-items center
						justify-content space-between
						width calc(100% - 30px)
						margin 0 auto
						height 55px
						.project-title
							font-weight 500
							font-size 1em
							color #fff
							letter-spacing .5px
						.icon
							width 30px
							height 30px
				.overlay
					width 100%
					height 100%
					position absolute
					background rgba(11,15,33,0.4)
					top 0
					left 0
					z-index 2
					opacity 0
					transition opacity .3s
				.project-splash-image
					width 100%
#contact-container
	width 100%
	background #0d1227
	display flex
	align-items center
	height fit-content
	position relative
	.graphic-container
		background #131933
		width 45%
		position absolute
		height 100%
		right 0
		overflow hidden
		.graphic-img
			width 40%
			position absolute
			top 50%
			left 50%
			transform translate(-50%, -50%)
			z-index 2
		.graphic-img-bg-elements
			width 70%
			position absolute
			top 50%
			left 50%
			transform translate(-50%, -50%)
			z-index 1
			opacity 0.01

	.form-container
		width 55%
		padding 60px 0
		.form-content
			width 85%
			margin 0 auto
			.title-container
				h1
					color #b8becc
					font-size 1.2em
					letter-spacing .5px
					font-weight 500
					line-height 100%
					margin-bottom 20px
				p
					color #fff
					font-size 2em
					font-weight 500
					letter-spacing .5px
			.form-elements
				width 100%
				margin-top 35px
				.input-container
					width 100%
					position relative
					margin-bottom 30px
					cursor text
					&.active
						.label
							font-size 0.8em !important
							top 8px !important
							transform translateY(0) !important
					input,
					textarea
						background #181f42
						outline none
						border none
						border-bottom 2px solid #374480
						font-size 1em
						color #fff
						z-index 2
						width 100%
						font-weight 500
						letter-spacing .5px
						padding 25px 15px 8px
						transition border-color .3s
						&:focus
							border-color #0043fe
						&:focus + .label
							color #0043fe
					textarea
						resize none
						height 150px
						& + .label
							top 25px
							transform none
					.label
						color #7c86b3
						z-index 1
						font-size 1em
						font-weight 500
						position absolute
						top calc(50% + 1px)
						left 15px
						transform translateY(-50%)
						transition color .3s, transform .3s, top .3s, font-size .3s
				.send-button
					background #0043fe
					width 150px
					float right
					border-radius 200px
					display flex
					align-items center
					padding 12px 0
					justify-content center
					cursor pointer
					transition background .3s
					&:hover
						background #0438ca
					.value
						color #fff
						font-size 0.95em
						font-weight 600
						letter-spacing .5px
						margin-right 8px
					.icon
						width 28px
						height 28px
#footer-container
	width 100%
	padding 50px 0
	border-top 2px solid #202746
	p
		text-align center
		color #b8becc
		letter-spacing .5px


					
@keyframes arrowBounce
	0%
		transform rotate(90deg) translateX(0)
	50%
		transform rotate(90deg) translateX(8px)
	100%
		transform rotate(90deg) translateX(0)

@keyframes arrowMove
	0%
		transform translateX(0)
	50%
		transform translateX(8px)
	100%
		transform translateX(0)